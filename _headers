/*
  # Security headers for Cloudflare Pages / Netlify
  # For GitHub Pages (which doesn't support _headers), use Cloudflare as a proxy
  # or add a meta http-equiv tag in each page's <head>.

  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-XSS-Protection: 1; mode=block

  # Content Security Policy — allows Google Fonts CDN and Formspree
  # Update the Formspree endpoint domain once confirmed.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://formspree.io; img-src 'self' data: https:; frame-ancestors 'none'
